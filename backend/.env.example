# Copy to backend/.env and fill in real values. .env is gitignored.

# ---- LLM ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- DB ----
# Matches docker-compose.yml. Override in prod.
DATABASE_URL=postgres://feynmap:feynmap@localhost:5432/feynmap

# ---- Auth ----
# Use `openssl rand -hex 32` to generate. Never commit a real value.
JWT_SECRET=replace-me-with-32-bytes-of-random
JWT_TTL=7d

# ---- Server ----
PORT=8787
