# Copy to backend/.env and fill in real values. .env is gitignored.

# ---- LLM ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- DB ----
# Local brew Postgres (the default path — see README).
# For docker-compose: postgres://feynmap:feynmap@localhost:5432/feynmap
DATABASE_URL=postgres://your-mac-username@localhost:5432/feynmap

# ---- Auth ----
# Use `openssl rand -hex 32` to generate. Never commit a real value.
JWT_SECRET=replace-me-with-32-bytes-of-random
JWT_TTL=7d

# ---- Server ----
PORT=8787
NODE_ENV=development

# ---- Seed ----
# Default org for `npm run db:seed`. Idempotent — safe to re-run.
SEED_ORG_SLUG=feynmap-dev
SEED_ORG_NAME=FeynMap (dev)

# Bootstrap a dev admin during seed. NEVER set both to true with a real
# password outside development. Skipped automatically when NODE_ENV=production.
SEED_DEV_ADMIN=false
SEED_DEV_EMAIL=admin@feynmap.local
SEED_DEV_PASSWORD=
