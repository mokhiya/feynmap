        <mxCell id="role" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" value="roles (per-org)&#xa;6 кодов" vertex="1">
