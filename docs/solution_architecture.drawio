        <mxCell id="grp_dev" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe9d6;strokeColor=#d79b00;align=left;verticalAlign=top;fontSize=12;fontColor=#8a5200;spacing=8;" value="Развитие: assignments · role_targets (gap-to-target leveling) · spaced_reviews (интервальные повторения)" vertex="1">
          <mxGeometry height="60" width="1420" x="40" y="570" as="geometry" />
        </mxCell>
        <mxCell id="grp_audit" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;align=left;verticalAlign=top;fontSize=12;fontColor=#444;spacing=8;" value="audit_logs — append-only, meta (JSONB): логины, заведение/блок пользователей, назначение ролей, KB-загрузка/переиндексация, override, апелляции." vertex="1">
          <mxGeometry height="60" width="1420" x="40" y="660" as="geometry" />
        </mxCell>
