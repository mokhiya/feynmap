  <diagram id="rbac" name="RBAC &amp; Data Model">
    <mxGraphModel dx="1244" dy="667" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bt" parent="1" style="text;html=1;align=left;fontSize=18;fontStyle=1;fontColor=#22243A;" value="RBAC и модель данных (multi-tenant по org_id)" vertex="1">
          <mxGeometry height="30" width="800" x="40" y="10" as="geometry" />
        </mxCell>
        <mxCell id="org" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontStyle=1;fontSize=12;" value="organizations&#xa;(арендатор)" vertex="1">
          <mxGeometry height="50" width="200" x="640" y="60" as="geometry" />
        </mxCell>
        <mxCell id="usr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" value="users&#xa;org_id · email · password_hash · locale · status" vertex="1">
          <mxGeometry height="60" width="280" x="120" y="170" as="geometry" />
        </mxCell>
        <mxCell id="ur" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" value="user_roles&#xa;(M:N)" vertex="1">
