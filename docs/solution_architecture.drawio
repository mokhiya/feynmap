        <mxCell id="rp" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" value="role_permissions&#xa;scope: own / team / org" vertex="1">
