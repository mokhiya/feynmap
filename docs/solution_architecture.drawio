        </mxCell>
        <mxCell id="perm" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" value="permissions&#xa;16 глобальных кодов" vertex="1">
          <mxGeometry height="50" width="200" x="1230" y="175" as="geometry" />
        </mxCell>
        <mxCell id="be1" edge="1" parent="1" source="org" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=open;strokeColor=#666;" target="usr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be2" edge="1" parent="1" source="org" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=open;strokeColor=#666;" target="role">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be3" edge="1" parent="1" source="usr" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=open;strokeColor=#6c8ebf;" target="ur">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be4" edge="1" parent="1" source="ur" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=open;strokeColor=#9673a6;" target="role">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be5" edge="1" parent="1" source="role" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=open;strokeColor=#9673a6;" target="rp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="be6" edge="1" parent="1" source="rp" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=open;strokeColor=#9673a6;" target="perm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="roles_list" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f3eef9;strokeColor=#9673a6;align=left;verticalAlign=top;fontSize=12;fontColor=#5b3a73;spacing=8;" value="6 ролей: admin · hr · assessor · mentor · learner_free · learner_assigned&#xa;(+ super_admin лениво)&#xa;Матрица — это данные (role_permissions), а не зашитые if. Напр.: hr имеет user.manage, но НЕ role.assign." vertex="1">
