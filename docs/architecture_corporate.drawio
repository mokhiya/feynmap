  <diagram id="corp-flow" name="Корпоративный слой — поток">
    <mxGraphModel dx="1400" dy="750" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1440" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;spacingTop=8;fontSize=12;arcSize=8;" value="&lt;b&gt;1. База знаний&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#1a4d80&quot;&gt;Администратор&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;загрузка → парсинг → чанки + эмбеддинги (pgvector)&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="200" x="40" y="180" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;spacingTop=8;fontSize=12;arcSize=8;" value="&lt;b&gt;2. Темы и уроки&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#3a6b1f&quot;&gt;Назначающий&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;конструктор из БЗ · ИИ-черновик компетенций&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="200" x="320" y="180" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;spacingTop=8;fontSize=12;arcSize=8;" value="&lt;b&gt;3. Назначения&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#a35a00&quot;&gt;HR · Наставник · Ассессор&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;тема/урок → сотруднику + дедлайн&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="200" x="600" y="180" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;spacingTop=8;fontSize=12;arcSize=8;" value="&lt;b&gt;4. Сессия «магия»&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#5b3a73&quot;&gt;Обучающийся&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Студент + Ассессор + живой радар · next_focus&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="200" x="880" y="180" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;spacingTop=8;fontSize=12;arcSize=8;" value="&lt;b&gt;5. Результаты и аналитика&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#7f6000&quot;&gt;Ассессор · HR&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;оценка против эталона · карты человек/команда/орг · ревью&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="200" x="1160" y="180" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="s1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#444444;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" target="s2" value="материал">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e23" edge="1" parent="1" source="s2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#444444;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" target="s3" value="тема / урок">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e34" edge="1" parent="1" source="s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#444444;fontSize=10;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" target="s4" value="старт сессии&#xa;(свободный — каталог · назначаемый — только назначенное)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e45" edge="1" parent="1" source="s4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#444444;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" target="s5" value="история → оценка">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_rag" edge="1" parent="1" source="s1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2e6fb5;strokeWidth=2;fontSize=11;fontColor=#1a4d80;labelBackgroundColor=#ffffff;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" target="s4" value="RAG-эталон: top-k чанков базы знаний">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="140" y="410" />
              <mxPoint x="980" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_fb" edge="1" parent="1" source="s5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;fontSize=11;fontColor=#5b3a73;labelBackgroundColor=#ffffff;dashed=1;exitX=0.5;exitY=0;entryX=0.5;entryY=0;" target="s3" value="аналитика → следующие назначения">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1260" y="110" />
              <mxPoint x="700" y="110" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#555555;spacing=4;" value="Корпоративный слой = надстройка над FeynMap. Базовое ядро (Студент / Ассессор / живой радар) — стадия 4, теперь заземлённое на загруженную базу знаний (RAG-эталон). Права проверяются на бэке по ролям." vertex="1">
          <mxGeometry height="40" width="900" x="40" y="430" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
