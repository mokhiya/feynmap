        <mxCell id="ux2" edge="1" parent="1" source="sc_topic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#b46504;fontSize=11;fontColor=#b46504;labelBackgroundColor=#ffffff;exitX=1;exitY=0.7;entryX=0;entryY=0.7;" target="sc_chat" value="«Продолжить сессию» (localStorage)">
