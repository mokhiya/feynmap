        </mxCell>
        <mxCell id="h_be" value="Backend (прокси)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="495" y="40" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h_student" value="Студент (LLM)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="735" y="40" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h_assessor" value="Ассессор (LLM)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="975" y="40" width="130" height="40" as="geometry" />
        </mxCell>
        <!-- ===== Линии жизни (пунктир вниз) ===== -->
        <mxCell id="ll_user" style="html=1;endArrow=none;dashed=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="80" as="sourcePoint" />
            <mxPoint x="100" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_fe" style="html=1;endArrow=none;dashed=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="80" as="sourcePoint" />
            <mxPoint x="330" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_be" style="html=1;endArrow=none;dashed=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="80" as="sourcePoint" />
            <mxPoint x="560" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_student" style="html=1;endArrow=none;dashed=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="80" as="sourcePoint" />
            <mxPoint x="800" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_assessor" style="html=1;endArrow=none;dashed=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1040" y="80" as="sourcePoint" />
            <mxPoint x="1040" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- ===== Сообщения (по возрастанию y, не пересекаются) ===== -->
        <mxCell id="s1" value="1. объясняет тему" style="html=1;endArrow=block;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="110" as="sourcePoint" />
            <mxPoint x="330" y="110" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s2" value="2. POST /assess (тема + история)" style="html=1;endArrow=block;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="160" as="sourcePoint" />
            <mxPoint x="560" y="160" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3" value="3. промпт оценки" style="html=1;endArrow=block;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="210" as="sourcePoint" />
            <mxPoint x="1040" y="210" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4" value="4. строгий JSON {competencies, next_focus, overall}" style="html=1;endArrow=open;rounded=0;dashed=1;strokeColor=#9673a6;fontColor=#5b3a73;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1040" y="260" as="sourcePoint" />
            <mxPoint x="560" y="260" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5" value="5. оценка → радар обновляется (анимация)" style="html=1;endArrow=open;rounded=0;dashed=1;strokeColor=#6c8ebf;fontColor=#22437a;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="310" as="sourcePoint" />
            <mxPoint x="330" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s6" value="6. POST /chat (история + next_focus)" style="html=1;endArrow=block;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="370" as="sourcePoint" />
            <mxPoint x="560" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s7" value="7. промпт + подсказка next_focus" style="html=1;endArrow=block;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="420" as="sourcePoint" />
            <mxPoint x="800" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s8" value="8. следующий наивный вопрос" style="html=1;endArrow=open;rounded=0;dashed=1;strokeColor=#9673a6;fontColor=#5b3a73;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="470" as="sourcePoint" />
            <mxPoint x="560" y="470" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s9" value="9. вопрос" style="html=1;endArrow=open;rounded=0;dashed=1;strokeColor=#6c8ebf;fontColor=#22437a;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="520" as="sourcePoint" />
            <mxPoint x="330" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s10" value="10. показывает вопрос студента" style="html=1;endArrow=block;rounded=0;strokeColor=#333333;fontSize=11;labelBackgroundColor=#ffffff;align=left;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="570" as="sourcePoint" />
            <mxPoint x="100" y="570" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- ===== Примечание о цикле ===== -->
        <mxCell id="note" value="Цикл повторяется на каждый ход пользователя: сначала оценка (radar + next_focus), затем адаптивный вопрос Студента в слабую зону. По кнопке «Завершить» Frontend вызывает /report и показывает финальный экран. Студент и Ассессор обращаются к LLM через единый provider-agnostic слой (облако или on-prem — по ENV)." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#555555;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="600" width="760" height="70" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="feynmap-ux" name="Экранный UX-флоу">
