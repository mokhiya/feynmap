        <mxCell id="ux1" edge="1" parent="1" source="sc_topic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#444444;fontSize=11;fontColor=#333333;labelBackgroundColor=#ffffff;exitX=1;exitY=0.33;entryX=0;entryY=0.33;" target="sc_chat" value="«Начать» → /chat (пустая история)">
